config BOARD_FREE3X_RIGHT
    select SOC_NRF52840_QIAA
    select ZMK_BOARD_COMPAT if BOARD_FREE3X_RIGHT_NRF52840_ZMK
    imply RETAINED_MEM if BOARD_FREE3X_RIGHT_NRF52840_ZMK
    imply RETENTION if BOARD_FREE3X_RIGHT_NRF52840_ZMK
    imply RETENTION_BOOT_MODE if BOARD_FREE3X_RIGHT_NRF52840_ZMK
