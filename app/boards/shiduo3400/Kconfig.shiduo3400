config BOARD_SHIDUO3400
    select SOC_NRF52840_QIAA
    select ZMK_BOARD_COMPAT if BOARD_SHIDUO3400_NRF52840_ZMK
    imply RETAINED_MEM if BOARD_SHIDUO3400_NRF52840_ZMK
    imply RETENTION if BOARD_SHIDUO3400_NRF52840_ZMK
    imply RETENTION_BOOT_MODE if BOARD_SHIDUO3400_NRF52840_ZMK
