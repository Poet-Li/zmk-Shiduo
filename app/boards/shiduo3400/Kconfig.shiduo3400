# shiduo3400 硬件能力声明。
# board.yml 中 name: shiduo3400 会自动生成对应的 BOARD_SHIDUO3400 符号。
config BOARD_SHIDUO3400
    # 指定芯片型号为 nRF52840-QIAA（QFN73 封装，1MB Flash，256KB RAM）
    select SOC_NRF52840_QIAA
    # 声明此板已按 ZMK 规范完整配置（Flash 分区、Bootloader 对接等）。
    # 条件：仅在使用 nrf52840/zmk 变体时生效
    select ZMK_BOARD_COMPAT if BOARD_SHIDUO3400_NRF52840_ZMK
    # 以下三条启用「保留内存」子系统，配合 nrf52840_uf2_boot_mode.dtsi，
    # 支持软件触发进入 UF2 Bootloader 刷机模式（&bootloader 按键 / 双击 Reset）。
    # 纯按键键盘也需要保留这三条。
    imply RETAINED_MEM if BOARD_SHIDUO3400_NRF52840_ZMK
    imply RETENTION if BOARD_SHIDUO3400_NRF52840_ZMK
    imply RETENTION_BOOT_MODE if BOARD_SHIDUO3400_NRF52840_ZMK
